ic below speech when both are present. - Maximize engagement, readability, relevance, smoothness, and retention. You should be able to decide the time duration where multiple caption should be placed on the screen at once, along with which word is important and what to color and highlight Elements:\n{\"version\":\"1.0\",\"video\":{\"size\":{\"width\":1080,\"height\":1920},\"fps\":30,\"bg_color\":[0,0,0],\"output_path\":\"output/a2v_video.mp4\"},\"elements\":[{\"element_id\":\"audio_1\",\"actions\":[{\"t_start\":0.0,\"t_end\":30.018,\"op\":\"play\",\"params\":{}}],\"properties\":{\"type\":\"music\",\"timing\":{\"start\":0.0,\"duration\":30.018},\"source_uri\":\"assets/inputs/song_0048.m4a\",\"loop\":true,\"volume\":1.0,\"trim_in\":0.0}},{\"element_id\":\"caption_track_1\",\"type\":\"caption\",\"timing\":{\"start\":0.031,\"duration\":29.987000000000002},\"actions\":[{\"t_start\":0.031,\"t_end\":30.018,\"op\":\"show\",\"params\":{}}],\"properties\":{\"type\":\"caption\",\"timing\":{\"start\":0.031,\"duration\":29.987000000000002},\"transform\":{\"x\":540.0,\"y\":1660.0,\"scale_x\":1.0,\"scale_y\":1.0,\"rotation_deg\":0.0,\"opacity\":1.0,\"anchor\":\"center\",\"size\":{},\"flip_x\":false,\"flip_y\":false},\"metadata\":{\"source\":\"asr_whisperx\",\"caption_mode\":\"single_combined_element\",\"word_timing_map\":[{\"index\":0,\"text\":\"But\",\"start\":0.031,\"end\":0.781},{\"index\":1,\"text\":\"I\",\"start\":0.781,\"end\":1.53},{\"index\":2,\"text\":\"kept\",\"start\":1.53,\"end\":2.28},{\"index\":3,\"text\":\"running\",\"start\":2.28,\"end\":3.03},{\"index\":4,\"text\":\"for\",\"start\":3.03,\"end\":3.779},{\"index\":5,\"text\":\"a\",\"start\":3.779,\"end\":4.529},{\"index\":6,\"text\":\"soft\",\"start\":4.529,\"end\":5.279},{\"index\":7,\"text\":\"place\",\"start\":5.279,\"end\":6.028},{\"index\":8,\"text\":\"to\",\"start\":6.028,\"end\":6.778},{\"index\":9,\"text\":\"fall\",\"start\":6.778,\"end\":7.528},{\"index\":10,\"text\":\"And\",\"start\":7.528,\"end\":8.277},{