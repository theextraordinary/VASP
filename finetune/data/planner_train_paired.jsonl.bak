kground music below speech when both are present. - Maximize engagement, readability, relevance, smoothness, and retention. You should be able to decide the time duration where multiple caption should be placed on the screen at once, along with which word is important and what to color and highlight Elements:\n{\"version\":\"1.0\",\"video\":{\"size\":{\"width\":1080,\"height\":1920},\"fps\":30,\"bg_color\":[0,0,0],\"output_path\":\"output/a2v_video.mp4\"},\"elements\":[{\"element_id\":\"audio_1\",\"actions\":[{\"t_start\":0.0,\"t_end\":6.106,\"op\":\"play\",\"params\":{}}],\"properties\":{\"type\":\"music\",\"timing\":{\"start\":0.0,\"duration\":6.106},\"source_uri\":\"assets/inputs/song_0030.m4a\",\"loop\":true,\"volume\":1.0,\"trim_in\":0.0}},{\"element_id\":\"caption_track_1\",\"type\":\"caption\",\"timing\":{\"start\":0.031,\"duration\":6.075},\"actions\":[{\"t_start\":0.031,\"t_end\":6.106,\"op\":\"show\",\"params\":{}}],\"properties\":{\"type\":\"caption\",\"timing\":{\"start\":0.031,\"duration\":6.075},\"transform\":{\"x\":540.0,\"y\":1660.0,\"scale_x\":1.0,\"scale_y\":1.0,\"rotation_deg\":0.0,\"opacity\":1.0,\"anchor\":\"center\",\"size\":{},\"flip_x\":false,\"flip_y\":false},\"metadata\":{\"source\":\"asr_whisperx\",\"caption_mode\":\"single_combined_element\",\"word_timing_map\":[{\"index\":0,\"text\":\"Neither\",\"start\":0.031,\"end\":0.369},{\"index\":1,\"text\":\"hurt\",\"start\":0.369,\"end\":0.706},{\"index\":2,\"text\":\"nor\",\"start\":0.706,\"end\":1.044},{\"index\":3,\"text\":\"lies\",\"start\":1.044,\"end\":1.381},{\"index\":4,\"text\":\"And\",\"start\":1.381,\"end\":1.718},{\"index\":5,\"text\":\"all\",\"start\":1.718,\"end\":2.056},{\"index\":6,\"text\":\"other\",\"start\":2.056,\"end\":2.394},{\"index\":7,\"text\":\"things\",\"start\":2.394,\"end\":2.731},{\"index\":8,\"text\":\"you\",\"start\":2.731,\"end\":3.069},{\"index\":9,\"text\":\"did\",\"start\":3.069,\"end\":3.406},{\"index\":10,\"text\":\"To\",\"start\":3.406,\"end\":3.744},{\"inde