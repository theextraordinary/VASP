ic below speech when both are present. - Maximize engagement, readability, relevance, smoothness, and retention. You should be able to decide the time duration where multiple caption should be placed on the screen at once, along with which word is important and what to color and highlight Elements:\n{\"version\":\"1.0\",\"video\":{\"size\":{\"width\":1080,\"height\":1920},\"fps\":30,\"bg_color\":[0,0,0],\"output_path\":\"output/a2v_video.mp4\"},\"elements\":[{\"element_id\":\"audio_1\",\"actions\":[{\"t_start\":0.0,\"t_end\":30.018,\"op\":\"play\",\"params\":{}}],\"properties\":{\"type\":\"music\",\"timing\":{\"start\":0.0,\"duration\":30.018},\"source_uri\":\"assets/inputs/song_0020.m4a\",\"loop\":true,\"volume\":1.0,\"trim_in\":0.0}},{\"element_id\":\"caption_track_1\",\"type\":\"caption\",\"timing\":{\"start\":3.288,\"duration\":26.73},\"actions\":[{\"t_start\":3.288,\"t_end\":30.018,\"op\":\"show\",\"params\":{}}],\"properties\":{\"type\":\"caption\",\"timing\":{\"start\":3.288,\"duration\":26.73},\"transform\":{\"x\":540.0,\"y\":1660.0,\"scale_x\":1.0,\"scale_y\":1.0,\"rotation_deg\":0.0,\"opacity\":1.0,\"anchor\":\"center\",\"size\":{},\"flip_x\":false,\"flip_y\":false},\"metadata\":{\"source\":\"asr_whisperx\",\"caption_mode\":\"single_combined_element\",\"word_timing_map\":[{\"index\":0,\"text\":\"Just\",\"start\":3.288,\"end\":4.098},{\"index\":1,\"text\":\"a\",\"start\":4.098,\"end\":4.908},{\"index\":2,\"text\":\"speck\",\"start\":4.908,\"end\":5.718},{\"index\":3,\"text\":\"of\",\"start\":5.718,\"end\":6.528},{\"index\":4,\"text\":\"dust\",\"start\":6.528,\"end\":7.338},{\"index\":5,\"text\":\"within\",\"start\":7.338,\"end\":8.148},{\"index\":6,\"text\":\"the\",\"start\":8.148,\"end\":8.958},{\"index\":7,\"text\":\"galaxy.\",\"start\":8.958,\"end\":9.768},{\"index\":8,\"text\":\"Whoa,\",\"start\":9.768,\"end\":10.578},{\"index\":9,\"text\":\"it's\",\"start\":10.578,\"end\":11.388},{\"index\":10,\"text\":\"me.\",\"start\":11.388,\"end\":12.198},{\"index\