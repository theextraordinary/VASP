kground music below speech when both are present. - Maximize engagement, readability, relevance, smoothness, and retention. You should be able to decide the time duration where multiple caption should be placed on the screen at once, along with which word is important and what to color and highlight Elements:\n{\"version\":\"1.0\",\"video\":{\"size\":{\"width\":1080,\"height\":1920},\"fps\":30,\"bg_color\":[0,0,0],\"output_path\":\"output/a2v_video.mp4\"},\"elements\":[{\"element_id\":\"audio_1\",\"actions\":[{\"t_start\":0.0,\"t_end\":26.474,\"op\":\"play\",\"params\":{}}],\"properties\":{\"type\":\"music\",\"timing\":{\"start\":0.0,\"duration\":26.474},\"source_uri\":\"assets/inputs/song_0043.m4a\",\"loop\":true,\"volume\":1.0,\"trim_in\":0.0}},{\"element_id\":\"caption_track_1\",\"type\":\"caption\",\"timing\":{\"start\":17.632,\"duration\":8.841999999999999},\"actions\":[{\"t_start\":17.632,\"t_end\":26.474,\"op\":\"show\",\"params\":{}}],\"properties\":{\"type\":\"caption\",\"timing\":{\"start\":17.632,\"duration\":8.841999999999999},\"transform\":{\"x\":540.0,\"y\":1660.0,\"scale_x\":1.0,\"scale_y\":1.0,\"rotation_deg\":0.0,\"opacity\":1.0,\"anchor\":\"center\",\"size\":{},\"flip_x\":false,\"flip_y\":false},\"metadata\":{\"source\":\"asr_whisperx\",\"caption_mode\":\"single_combined_element\",\"word_timing_map\":[{\"index\":0,\"text\":\"When\",\"start\":17.632,\"end\":18.074},{\"index\":1,\"text\":\"I\",\"start\":18.074,\"end\":18.516},{\"index\":2,\"text\":\"was\",\"start\":18.516,\"end\":18.958},{\"index\":3,\"text\":\"listening\",\"start\":18.958,\"end\":19.4},{\"index\":4,\"text\":\"to\",\"start\":19.4,\"end\":19.843},{\"index\":5,\"text\":\"the\",\"start\":19.843,\"end\":20.285},{\"index\":6,\"text\":\"ocean\",\"start\":20.285,\"end\":20.727},{\"index\":7,\"text\":\"I\",\"start\":20.727,\"end\":21.169},{\"index\":8,\"text\":\"saw\",\"start\":21.169,\"end\":21.611},{\"index\":9,\"text\":\"a\",\"start\":21.611,\"end\":22.053},{\"index\":10,\"text\":\"face\"