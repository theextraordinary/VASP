d music below speech when both are present. - Maximize engagement, readability, relevance, smoothness, and retention. You should be able to decide the time duration where multiple caption should be placed on the screen at once, along with which word is important and what to color and highlight Elements:\n{\"version\":\"1.0\",\"video\":{\"size\":{\"width\":1080,\"height\":1920},\"fps\":30,\"bg_color\":[0,0,0],\"output_path\":\"output/a2v_video.mp4\"},\"elements\":[{\"element_id\":\"audio_1\",\"actions\":[{\"t_start\":0.0,\"t_end\":25.816,\"op\":\"play\",\"params\":{}}],\"properties\":{\"type\":\"music\",\"timing\":{\"start\":0.0,\"duration\":25.816},\"source_uri\":\"assets/inputs/song_0019.m4a\",\"loop\":true,\"volume\":1.0,\"trim_in\":0.0}},{\"element_id\":\"caption_track_1\",\"type\":\"caption\",\"timing\":{\"start\":0.706,\"duration\":25.11},\"actions\":[{\"t_start\":0.706,\"t_end\":25.816,\"op\":\"show\",\"params\":{}}],\"properties\":{\"type\":\"caption\",\"timing\":{\"start\":0.706,\"duration\":25.11},\"transform\":{\"x\":540.0,\"y\":1660.0,\"scale_x\":1.0,\"scale_y\":1.0,\"rotation_deg\":0.0,\"opacity\":1.0,\"anchor\":\"center\",\"size\":{},\"flip_x\":false,\"flip_y\":false},\"metadata\":{\"source\":\"asr_whisperx\",\"caption_mode\":\"single_combined_element\",\"word_timing_map\":[{\"index\":0,\"text\":\"Tell\",\"start\":0.706,\"end\":1.467},{\"index\":1,\"text\":\"us\",\"start\":1.467,\"end\":2.228},{\"index\":2,\"text\":\"the\",\"start\":2.228,\"end\":2.989},{\"index\":3,\"text\":\"reason\",\"start\":2.989,\"end\":3.75},{\"index\":4,\"text\":\"he's\",\"start\":3.75,\"end\":4.511},{\"index\":5,\"text\":\"wasted\",\"start\":4.511,\"end\":5.271},{\"index\":6,\"text\":\"on\",\"start\":5.271,\"end\":6.032},{\"index\":7,\"text\":\"the\",\"start\":6.032,\"end\":6.793},{\"index\":8,\"text\":\"young\",\"start\":6.793,\"end\":7.554},{\"index\":9,\"text\":\"It's\",\"start\":7.554,\"end\":8.315},{\"index\":10,\"text\":\"hunting\",\"start\":8.315,\"end\":9.076},{\"index\