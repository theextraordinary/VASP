round music below speech when both are present. - Maximize engagement, readability, relevance, smoothness, and retention. You should be able to decide the time duration where multiple caption should be placed on the screen at once, along with which word is important and what to color and highlight Elements:\n{\"version\":\"1.0\",\"video\":{\"size\":{\"width\":1080,\"height\":1920},\"fps\":30,\"bg_color\":[0,0,0],\"output_path\":\"output/a2v_video.mp4\"},\"elements\":[{\"element_id\":\"audio_1\",\"actions\":[{\"t_start\":0.0,\"t_end\":30.018,\"op\":\"play\",\"params\":{}}],\"properties\":{\"type\":\"music\",\"timing\":{\"start\":0.0,\"duration\":30.018},\"source_uri\":\"assets/inputs/song_0040.m4a\",\"loop\":true,\"volume\":1.0,\"trim_in\":0.0}},{\"element_id\":\"caption_track_1\",\"type\":\"caption\",\"timing\":{\"start\":0.031,\"duration\":29.987000000000002},\"actions\":[{\"t_start\":0.031,\"t_end\":30.018,\"op\":\"show\",\"params\":{}}],\"properties\":{\"type\":\"caption\",\"timing\":{\"start\":0.031,\"duration\":29.987000000000002},\"transform\":{\"x\":540.0,\"y\":1660.0,\"scale_x\":1.0,\"scale_y\":1.0,\"rotation_deg\":0.0,\"opacity\":1.0,\"anchor\":\"center\",\"size\":{},\"flip_x\":false,\"flip_y\":false},\"metadata\":{\"source\":\"asr_whisperx\",\"caption_mode\":\"single_combined_element\",\"word_timing_map\":[{\"index\":0,\"text\":\"Made\",\"start\":0.031,\"end\":0.656},{\"index\":1,\"text\":\"for\",\"start\":0.656,\"end\":1.28},{\"index\":2,\"text\":\"saying\",\"start\":1.28,\"end\":1.905},{\"index\":3,\"text\":\"things\",\"start\":1.905,\"end\":2.53},{\"index\":4,\"text\":\"that\",\"start\":2.53,\"end\":3.155},{\"index\":5,\"text\":\"you\",\"start\":3.155,\"end\":3.779},{\"index\":6,\"text\":\"can't\",\"start\":3.779,\"end\":4.404},{\"index\":7,\"text\":\"say\",\"start\":4.404,\"end\":5.029},{\"index\":8,\"text\":\"tomorrow\",\"start\":5.029,\"end\":5.654},{\"index\":9,\"text\":\"day\",\"start\":5.654,\"end\":6.278},{\"index\":10,\"text\":\"Crawling\",\"sta