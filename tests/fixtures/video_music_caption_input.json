{
  "video": {
    "size": { "width": 1080, "height": 1920 },
    "fps": 30,
    "bg_color": [0, 0, 0],
    "output_path": "output/video_music_caption_test.mp4"
  },
  "elements": {
    "cap_intro": {
      "type": "caption",
      "text": "This is AI",
      "transform": { "x": 540, "y": 240 }
    },
    "vid_first": {
      "type": "video",
      "source_uri": "assets/inputs/video.mp4",
      "length": 6.0,
      "transform": { "x": 540, "y": 900 }
    },
    "cap_line1": {
      "type": "caption",
      "text": "A man enters the house",
      "transform": { "x": 540, "y": 1500 }
    },
    "cap_mid": {
      "type": "caption",
      "text": "second time",
      "transform": { "x": 540, "y": 960 }
    },
    "cap_bye": {
      "type": "caption",
      "text": "ByeBye",
      "transform": { "x": 540, "y": 960 }
    },
    "vid_second": {
      "type": "video",
      "source_uri": "assets/inputs/video_second.mp4",
      "length": 12.0,
      "transform": { "x": 540, "y": 900 }
    },
    "cap_line2": {
      "type": "caption",
      "text": "A man enters house again",
      "transform": { "x": 540, "y": 1500 }
    },
    "music_first": {
      "type": "music",
      "source_uri": "assets/inputs/music.mp3",
      "length": 210.0
    },
    "music_last": {
      "type": "music",
      "source_uri": "assets/inputs/music.mp3",
      "length": 210.0
    }
  },
  "segments": [
    {
      "id": "intro",
      "t_start": 0.0,
      "t_end": 2.0,
      "elements": [
        {
          "ref": "cap_intro",
          "actions": [
            {
              "op": "show",
              "params": { "font_size": 72, "font_weight": "bold", "font_style": "normal", "color": "#FFFFFF" }
            }
          ]
        }
      ]
    },
    {
      "id": "scene1",
      "t_start": 2.0,
      "t_end": 8.0,
      "elements": [
        {
          "ref": "vid_first",
          "actions": [
            { "op": "show", "params": { "trim_in": 0.0, "trim_out": 6.0, "scale": 1.0 } }
          ]
        },
        {
          "ref": "cap_line1",
          "actions": [
            { "op": "show", "params": { "font_size": 48, "font_weight": "regular", "font_style": "italic", "color": "#F2F2F2" } }
          ]
        },
        {
          "ref": "music_first",
          "actions": [
            { "op": "play", "params": { "trim_in": 0.0, "trim_out": 6.0, "volume": 0.9 } }
          ]
        }
      ]
    },
    {
      "id": "mid_caption",
      "t_start": 8.0,
      "t_end": 9.0,
      "elements": [
        {
          "ref": "cap_mid",
          "actions": [
            { "op": "show", "params": { "font_size": 64, "font_weight": "bold", "font_style": "normal", "color": "#FFFFFF" } }
          ]
        }
      ]
    },
    {
      "id": "scene2",
      "t_start": 9.0,
      "t_end": 15.0,
      "elements": [
        {
          "ref": "vid_second",
          "actions": [
            { "op": "show", "params": { "trim_in": 0.0, "trim_out": 6.0, "scale": 1.0 } }
          ]
        },
        {
          "ref": "cap_line2",
          "actions": [
            { "op": "show", "params": { "font_size": 48, "font_weight": "regular", "font_style": "italic", "color": "#F2F2F2" } }
          ]
        }
      ]
    },
    {
      "id": "outro",
      "t_start": 15.0,
      "t_end": 18.0,
      "elements": [
        {
          "ref": "music_last",
          "actions": [
            { "op": "play", "params": { "trim_in": 205.0, "trim_out": 208.0, "volume": 0.9 } }
          ]
        },
        {
          "ref": "cap_bye",
          "actions": [
            { "op": "show", "params": { "font_size": 68, "font_weight": "bold", "font_style": "italic", "color": "#00E5FF" } }
          ]
        }
      ]
    }
  ]
}
